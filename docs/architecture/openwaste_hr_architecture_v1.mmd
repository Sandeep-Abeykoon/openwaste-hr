flowchart LR
    %% OpenWaste-HR Architecture Diagram v1

    subgraph DATA["Dataset and Data Management"]
        RAW["Raw known datasets<br/>TrashNet-style folders"]
        LOCAL["Local unknown dataset<br/>phone-captured images"]
        MANIFEST["Dataset manifest builder<br/>standard CSV records"]
        SPLITS["Train / validation / test splits"]
        INSPECT["Dataset inspection<br/>labels, images, imbalance"]
    end

    subgraph TRAINING["Model Training and Evaluation"]
        TRAIN["Baseline model training<br/>MobileNetV3-style classifier"]
        CHECKPOINT["Best model checkpoint<br/>baseline_trashnet_best.pt"]
        CLOSED["Closed-set evaluation<br/>accuracy and F1"]
        REJECT["Reject-option baselines<br/>confidence, max-logit, energy"]
        UNKNOWN_EVAL["Local unknown evaluation<br/>unknown rejection and false acceptance"]
    end

    subgraph POLICY["Hierarchical Decision Layer"]
        TAXONOMY["Hierarchical taxonomy<br/>fine labels to coarse labels"]
        POLICY_V1["Hierarchical policy v1<br/>fine_label / coarse_label / manual_review"]
        SAFE_TUNE["Safe policy tuning<br/>stricter thresholds"]
        FINAL_POLICY["Selected safe policy<br/>fine, coarse, or manual_review"]
    end

    subgraph ACTIVE["Local Active Learning Loop"]
        CANDIDATES["Active learning candidate selection<br/>uncertain and risky local images"]
        HUMAN_SHEET["Human labelling sheet<br/>20 selected candidates"]
        REVIEW_PROCESS["Reviewed label processing<br/>dataset actions"]
        DATASET_V2["Future dataset v2<br/>reviewed local feedback"]
    end

    subgraph INFERENCE["Inference Layer"]
        SINGLE["Single-image inference<br/>one image path"]
        BATCH["Batch inference<br/>folder of images"]
        API_WRAPPER["Prototype API wrapper<br/>stable JSON response"]
    end

    subgraph BACKEND["Backend Layer"]
        FASTAPI["FastAPI backend"]
        HEALTH["GET /health"]
        PREDICT["POST /api/inference/predict"]
    end

    subgraph FRONTEND["Frontend Demo"]
        UI["Simple HTML/CSS/JS page"]
        FORM["Image path input<br/>sample ID input"]
        RESULT["Decision display<br/>label, confidence, probabilities"]
    end

    RAW --> MANIFEST
    LOCAL --> MANIFEST
    MANIFEST --> SPLITS
    SPLITS --> INSPECT
    SPLITS --> TRAIN

    TRAIN --> CHECKPOINT
    CHECKPOINT --> CLOSED
    CHECKPOINT --> REJECT
    CHECKPOINT --> UNKNOWN_EVAL

    TAXONOMY --> POLICY_V1
    CLOSED --> POLICY_V1
    REJECT --> POLICY_V1
    UNKNOWN_EVAL --> POLICY_V1
    POLICY_V1 --> SAFE_TUNE
    SAFE_TUNE --> FINAL_POLICY

    FINAL_POLICY --> CANDIDATES
    LOCAL --> CANDIDATES
    CANDIDATES --> HUMAN_SHEET
    HUMAN_SHEET --> REVIEW_PROCESS
    REVIEW_PROCESS --> DATASET_V2
    DATASET_V2 -. future retraining .-> TRAIN

    CHECKPOINT --> SINGLE
    CHECKPOINT --> BATCH
    FINAL_POLICY --> SINGLE
    FINAL_POLICY --> BATCH
    SINGLE --> API_WRAPPER

    API_WRAPPER --> FASTAPI
    FASTAPI --> HEALTH
    FASTAPI --> PREDICT

    UI --> FORM
    FORM --> PREDICT
    PREDICT --> API_WRAPPER
    PREDICT --> RESULT
    RESULT --> UI